# LM Studio local AI backend
VITE_LM_STUDIO_BASE_URL=http://localhost:1234/v1
VITE_LM_STUDIO_MODEL=local-model
VITE_LM_STUDIO_TEMPERATURE=0.7
VITE_LM_STUDIO_MAX_TOKENS=1024

# Tree / graph constraints
VITE_MAX_TREE_DEPTH=6
VITE_MAX_TREE_BREADTH=5

# Rendering options
VITE_ENABLE_SCENE_ROTATION=false
